// This Pine Script™ is subject to the Terms of Use at https://www.tradingview.com/pine-script-docs/
// © 이평매매v2 Strategy — 사용자 지표 기반 백테스트
//@version=6
strategy("이평매매v2 백테스트", overlay=true, default_qty_type=strategy.percent_of_equity,
         initial_capital=10000, commission_type=strategy.commission.percent,
         commission_value=0.04, slippage=1, pyramiding=4,
         calc_on_every_tick=false, max_lines_count=500, max_labels_count=500)

// ╔════════════════════════════════════════════════════════════╗
// ║  백테스트 기간 (에센셜 플랜용)                               ║
// ╚════════════════════════════════════════════════════════════╝
grpDate = "백테스트 기간"
i_start_year  = input.int(2025, "시작 연도", group=grpDate)
i_start_month = input.int(8,    "시작 월", minval=1, maxval=12, group=grpDate)
i_start_day   = input.int(1,    "시작 일", minval=1, maxval=31, group=grpDate)
i_end_year    = input.int(2026, "종료 연도", group=grpDate)
i_end_month   = input.int(3,    "종료 월", minval=1, maxval=12, group=grpDate)
i_end_day     = input.int(20,   "종료 일", minval=1, maxval=31, group=grpDate)

start_time    = timestamp(i_start_year, i_start_month, i_start_day, 0, 0)
end_time      = timestamp(i_end_year,   i_end_month,   i_end_day,   23, 59)
in_date_range = time >= start_time and time <= end_time

// 기간 밖 → 전량 청산
if not in_date_range and strategy.position_size != 0
    strategy.close_all(comment="기간종료_전량청산")

// ╔════════════════════════════════════════════════════════════╗
// ║  매매 방향                                                 ║
// ╚════════════════════════════════════════════════════════════╝
grpMode = "매매 설정"
i_mode = input.string("롱", "매매 방향", options=["롱", "숏", "단타"], group=grpMode)

// ╔════════════════════════════════════════════════════════════╗
// ║  이평매매v2 지표 — ZLSMA 150                               ║
// ╚════════════════════════════════════════════════════════════╝
grpZ = "ZLSMA"
shZLS  = input.bool(true,  "Show ZLSMA", group=grpZ)
lenZLS = input.int(150, "ZLSMA Length", minval=1, group=grpZ)
offZLS = input.int(0,   "ZLSMA Offset", group=grpZ)
srcZLS = input.source(close, "ZLSMA Source", group=grpZ)

zlsma_func(_src, _len, _off) =>
    _lsma  = ta.linreg(_src,  _len, _off)
    _lsma2 = ta.linreg(_lsma, _len, _off)
    _lsma + (_lsma - _lsma2)

zlsma = zlsma_func(srcZLS, lenZLS, offZLS)

// ╔════════════════════════════════════════════════════════════╗
// ║  이평매매v2 지표 — ALMA 50                                 ║
// ╚════════════════════════════════════════════════════════════╝
grpA = "ALMA"
shALMA  = input.bool(true, "Show ALMA", group=grpA)
lenALMA = input.int(50, "ALMA Length", minval=1, group=grpA)
offALMA = input.float(0.9, "ALMA Offset", step=0.01, group=grpA)
sigALMA = input.float(6.0, "ALMA Sigma", group=grpA)

alma50 = ta.alma(close, lenALMA, offALMA, sigALMA)

// ╔════════════════════════════════════════════════════════════╗
// ║  이평매매v2 지표 — VWMA 150, HMA 34                        ║
// ╚════════════════════════════════════════════════════════════╝
grpCore = "Core MAs"
lenVWMA = input.int(150, "VWMA Length", minval=1, group=grpCore)
lenHMA  = input.int(34,  "HMA Length",  minval=1, group=grpCore)

vwma150 = ta.vwma(close, lenVWMA)
hma34   = ta.hma(close, lenHMA)

// ╔════════════════════════════════════════════════════════════╗
// ║  이평매매v2 지표 — 볼린저밴드 (BB 25)                       ║
// ╚════════════════════════════════════════════════════════════╝
grpBB = "Bollinger Bands"
bbLen    = input.int(25, "BB Length", minval=1, group=grpBB)
bbMaType = input.string("SMA", "BB MA Type", options=["SMA","EMA","SMMA (RMA)","WMA","VWMA"], group=grpBB)
bbSrc    = input.source(close, "BB Source", group=grpBB)
bbMult   = input.float(2.0, "BB StdDev", minval=0.001, maxval=50, group=grpBB)
bbOff    = input.int(0, "BB Offset", minval=-500, maxval=500, group=grpBB)

bb_ma(source, length, _type) =>
    switch _type
        "SMA"         => ta.sma(source, length)
        "EMA"         => ta.ema(source, length)
        "SMMA (RMA)"  => ta.rma(source, length)
        "WMA"         => ta.wma(source, length)
        "VWMA"        => ta.vwma(source, length)

bbBasis = bb_ma(bbSrc, bbLen, bbMaType)
bbDev   = bbMult * ta.stdev(bbSrc, bbLen)
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

// ╔════════════════════════════════════════════════════════════╗
// ║  7EMA_5MA 지표 — EMA 21/55/100/200/300/400                ║
// ║                   SMA 11/23/25/39/200                     ║
// ╚════════════════════════════════════════════════════════════╝
grpEMA = "7 EMA"
len_ema1 = input.int(21,  "EMA 1", group=grpEMA)
len_ema2 = input.int(55,  "EMA 2", group=grpEMA)
len_ema3 = input.int(100, "EMA 3", group=grpEMA)
len_ema4 = input.int(200, "EMA 4", group=grpEMA)
len_ema5 = input.int(300, "EMA 5", group=grpEMA)
len_ema6 = input.int(400, "EMA 6", group=grpEMA)

grpSMA = "5 SMA"
len_ma1 = input.int(11,  "SMA 1", group=grpSMA)
len_ma2 = input.int(23,  "SMA 2", group=grpSMA)
len_ma3 = input.int(25,  "SMA 3", group=grpSMA)
len_ma4 = input.int(39,  "SMA 4", group=grpSMA)
len_ma5 = input.int(200, "SMA 5", group=grpSMA)

ema_21  = ta.ema(close, len_ema1)
ema_55  = ta.ema(close, len_ema2)
ema_100 = ta.ema(close, len_ema3)
ema_200 = ta.ema(close, len_ema4)
ema_300 = ta.ema(close, len_ema5)
ema_400 = ta.ema(close, len_ema6)

sma_11  = ta.sma(close, len_ma1)
sma_23  = ta.sma(close, len_ma2)
sma_25  = ta.sma(close, len_ma3)
sma_39  = ta.sma(close, len_ma4)
sma_200 = ta.sma(close, len_ma5)

// ╔════════════════════════════════════════════════════════════╗
// ║  4H / 1H 멀티타임프레임 데이터                              ║
// ╚════════════════════════════════════════════════════════════╝
// 4H 볼린저밴드
bb4h_basis_raw = request.security(syminfo.tickerid, "240", bb_ma(bbSrc, bbLen, bbMaType))
bb4h_dev_raw   = request.security(syminfo.tickerid, "240", bbMult * ta.stdev(bbSrc, bbLen))
bb4h_upper = bb4h_basis_raw + bb4h_dev_raw
bb4h_lower = bb4h_basis_raw - bb4h_dev_raw

// 1H 볼린저밴드 (익절 기준)
bb1h_basis_raw = request.security(syminfo.tickerid, "60", bb_ma(bbSrc, bbLen, bbMaType))
bb1h_dev_raw   = request.security(syminfo.tickerid, "60", bbMult * ta.stdev(bbSrc, bbLen))
bb1h_upper = bb1h_basis_raw + bb1h_dev_raw
bb1h_lower = bb1h_basis_raw - bb1h_dev_raw

// 1H ZLSMA (익절 기준)
zlsma_1h = request.security(syminfo.tickerid, "60", zlsma)

// 15분봉 거래량
grpVol = "거래량 서지"
i_vol_count = input.int(8,    "비교 캔들 수", group=grpVol)
i_vol_mult  = input.float(2.0, "배수", group=grpVol)

vol_15m     = request.security(syminfo.tickerid, "15", volume)
vol_15m_avg = request.security(syminfo.tickerid, "15", ta.sma(volume, i_vol_count))
vol_surge   = vol_15m >= vol_15m_avg * i_vol_mult

// ╔════════════════════════════════════════════════════════════╗
// ║  캔들 패턴 감지                                            ║
// ╚════════════════════════════════════════════════════════════╝
body_size    = math.abs(close - open)
total_range  = high - low
lower_shadow = math.min(open, close) - low
upper_shadow = high - math.max(open, close)

// 망치형 (Hammer)
is_hammer = total_range > 0 and
             lower_shadow >= 2 * body_size and
             upper_shadow <= body_size * 0.5 and
             body_size / total_range <= 0.35

// 강세 장악형 (Bullish Engulfing)
is_bull_engulfing = close[1] < open[1] and close > open and
                     open <= close[1] and close >= open[1]

// 역망치형 (Inverted Hammer / Shooting Star)
is_inv_hammer = total_range > 0 and
                 upper_shadow >= 2 * body_size and
                 lower_shadow <= body_size * 0.5 and
                 body_size / total_range <= 0.35

// 약세 장악형 (Bearish Engulfing)
is_bear_engulfing = close[1] > open[1] and close < open and
                     open >= close[1] and close <= open[1]

bullish_pattern = is_hammer or is_bull_engulfing
bearish_pattern = is_inv_hammer or is_bear_engulfing

// ╔════════════════════════════════════════════════════════════╗
// ║  진입 조건                                                 ║
// ║  EMA21 → 선진입 (기존 EMA25 역할)                          ║
// ║  EMA55 → 메인진입 (기존 EMA50 역할)                        ║
// ║  VWMA150 → 강한 지지/저항 확인                             ║
// ╚════════════════════════════════════════════════════════════╝
grpSize = "포지션 크기"
i_size_ema21     = input.float(10, "EMA21 진입 (%)",      group=grpSize)
i_size_ema55     = input.float(50, "EMA55 진입 (%)",      group=grpSize)
i_size_ema55vwma = input.float(20, "EMA55+VWMA 진입 (%)", group=grpSize)
i_size_bb4h      = input.float(20, "4H BB 진입 (%)",      group=grpSize)
i_max_position   = input.float(80, "최대 포지션 (%)",      group=grpSize)

grpTP = "익절/손절"
i_tp1_pct = input.float(30, "TP1 청산 비율 (%)", group=grpTP)
i_tp2_pct = input.float(30, "TP2 청산 비율 (%)", group=grpTP)

// -- ZLSMA 방향 --
zlsma_positive = close > zlsma
zlsma_negative = close < zlsma

// -- EMA21 터치 (선진입용) --
touches_ema21 = low <= ema_21 and high >= ema_21
close_above_ema21 = close > ema_21
close_below_ema21 = close < ema_21

// -- EMA55 터치 (메인 진입용) --
touches_ema55 = low <= ema_55 and high >= ema_55
close_above_ema55 = close > ema_55
close_below_ema55 = close < ema_55

// -- VWMA150 터치 --
touches_vwma = low <= vwma150 and high >= vwma150

// -- 4H BB 터치 --
touches_bb4h_lower = low <= bb4h_lower
close_above_bb4h   = close > bb4h_lower
touches_bb4h_upper = high >= bb4h_upper
close_below_bb4h   = close < bb4h_upper

// ── 롱 조건 ──
long_common = in_date_range and zlsma_positive and vol_surge and bullish_pattern

long_cond1 = long_common and touches_ema21 and close_above_ema21           // EMA21 선진입 10%
long_cond2 = long_common and touches_ema55 and close_above_ema55           // EMA55 메인   50%
long_cond3 = long_common and touches_ema55 and touches_vwma and close_above_ema55  // EMA55+VWMA 20%
long_cond4 = long_common and touches_bb4h_lower and close_above_bb4h       // 4H BB하단   20%

// ── 숏 조건 ──
short_common = in_date_range and zlsma_negative and vol_surge and bearish_pattern

short_cond1 = short_common and touches_ema21 and close_below_ema21
short_cond2 = short_common and touches_ema55 and close_below_ema55
short_cond3 = short_common and touches_ema55 and touches_vwma and close_below_ema55
short_cond4 = short_common and touches_bb4h_upper and close_below_bb4h

// ╔════════════════════════════════════════════════════════════╗
// ║  포지션 추적                                               ║
// ╚════════════════════════════════════════════════════════════╝
var float total_invested_pct = 0.0
var bool  tp1_done = false
var bool  tp2_done = false
var float pattern_sl_price = 0.0
var string last_entry_type = ""

in_long     = strategy.position_size > 0
in_short    = strategy.position_size < 0
no_position = strategy.position_size == 0

if no_position
    total_invested_pct := 0.0
    tp1_done := false
    tp2_done := false
    pattern_sl_price := 0.0
    last_entry_type := ""

can_add = total_invested_pct < i_max_position

allow_long  = i_mode == "롱" or i_mode == "단타"
allow_short = i_mode == "숏" or i_mode == "단타"

// SL 기준 저점/고점
bull_pattern_low  = is_bull_engulfing ? low[1] : low
bear_pattern_high = is_bear_engulfing ? high[1] : high

// ╔════════════════════════════════════════════════════════════╗
// ║  롱 진입 (우선순위: 조건3 > 조건2 > 조건1, 조건4 독립)     ║
// ╚════════════════════════════════════════════════════════════╝
if allow_long and can_add and long_cond3 and (total_invested_pct + i_size_ema55vwma) <= i_max_position
    strategy.entry("L_EMA55_VWMA", strategy.long, qty=strategy.equity * i_size_ema55vwma / 100 / close)
    total_invested_pct += i_size_ema55vwma
    pattern_sl_price := bull_pattern_low
    last_entry_type := "ema55_vwma"
else if allow_long and can_add and long_cond2 and (total_invested_pct + i_size_ema55) <= i_max_position
    strategy.entry("L_EMA55", strategy.long, qty=strategy.equity * i_size_ema55 / 100 / close)
    total_invested_pct += i_size_ema55
    pattern_sl_price := bull_pattern_low
    last_entry_type := "ema55"
else if allow_long and can_add and long_cond1 and (total_invested_pct + i_size_ema21) <= i_max_position
    strategy.entry("L_EMA21", strategy.long, qty=strategy.equity * i_size_ema21 / 100 / close)
    total_invested_pct += i_size_ema21
    pattern_sl_price := bull_pattern_low
    last_entry_type := "ema21"

if allow_long and can_add and long_cond4 and (total_invested_pct + i_size_bb4h) <= i_max_position
    strategy.entry("L_BB4H", strategy.long, qty=strategy.equity * i_size_bb4h / 100 / close)
    total_invested_pct += i_size_bb4h
    if pattern_sl_price == 0.0
        pattern_sl_price := bull_pattern_low
    last_entry_type := "bb4h"

// ╔════════════════════════════════════════════════════════════╗
// ║  숏 진입                                                   ║
// ╚════════════════════════════════════════════════════════════╝
if allow_short and can_add and short_cond3 and (total_invested_pct + i_size_ema55vwma) <= i_max_position
    strategy.entry("S_EMA55_VWMA", strategy.short, qty=strategy.equity * i_size_ema55vwma / 100 / close)
    total_invested_pct += i_size_ema55vwma
    pattern_sl_price := bear_pattern_high
    last_entry_type := "ema55_vwma"
else if allow_short and can_add and short_cond2 and (total_invested_pct + i_size_ema55) <= i_max_position
    strategy.entry("S_EMA55", strategy.short, qty=strategy.equity * i_size_ema55 / 100 / close)
    total_invested_pct += i_size_ema55
    pattern_sl_price := bear_pattern_high
    last_entry_type := "ema55"
else if allow_short and can_add and short_cond1 and (total_invested_pct + i_size_ema21) <= i_max_position
    strategy.entry("S_EMA21", strategy.short, qty=strategy.equity * i_size_ema21 / 100 / close)
    total_invested_pct += i_size_ema21
    pattern_sl_price := bear_pattern_high
    last_entry_type := "ema21"

if allow_short and can_add and short_cond4 and (total_invested_pct + i_size_bb4h) <= i_max_position
    strategy.entry("S_BB4H", strategy.short, qty=strategy.equity * i_size_bb4h / 100 / close)
    total_invested_pct += i_size_bb4h
    if pattern_sl_price == 0.0
        pattern_sl_price := bear_pattern_high
    last_entry_type := "bb4h"

// ╔════════════════════════════════════════════════════════════╗
// ║  익절 (TP)                                                 ║
// ╚════════════════════════════════════════════════════════════╝
// ── 롱 익절 ──
if in_long
    pos_qty = math.abs(strategy.position_size)
    // TP1: 1H ZLSMA 도달 → 30%
    if not tp1_done and close >= zlsma_1h
        tp1_qty = pos_qty * (i_tp1_pct / 100)
        strategy.close("L_EMA21",      qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("L_EMA55",      qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("L_EMA55_VWMA", qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("L_BB4H",       qty=tp1_qty, comment="TP1_ZLSMA")
        tp1_done := true

    // TP2: 1H BB 상단 도달 → 30%
    if not tp2_done and tp1_done and close >= bb1h_upper
        rem_qty = math.abs(strategy.position_size)
        tp2_qty = rem_qty * (i_tp2_pct / (100 - i_tp1_pct)) * 100 / 100
        strategy.close("L_EMA21",      qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("L_EMA55",      qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("L_EMA55_VWMA", qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("L_BB4H",       qty=tp2_qty, comment="TP2_BB1H")
        tp2_done := true

    // TP3: 평단 이하 도달 → 전량
    if tp2_done and close <= strategy.position_avg_price
        strategy.close_all(comment="TP3_평단청산")

// ── 숏 익절 ──
if in_short
    pos_qty = math.abs(strategy.position_size)
    if not tp1_done and close <= zlsma_1h
        tp1_qty = pos_qty * (i_tp1_pct / 100)
        strategy.close("S_EMA21",      qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("S_EMA55",      qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("S_EMA55_VWMA", qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("S_BB4H",       qty=tp1_qty, comment="TP1_ZLSMA")
        tp1_done := true

    if not tp2_done and tp1_done and close <= bb1h_lower
        rem_qty = math.abs(strategy.position_size)
        tp2_qty = rem_qty * (i_tp2_pct / (100 - i_tp1_pct)) * 100 / 100
        strategy.close("S_EMA21",      qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("S_EMA55",      qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("S_EMA55_VWMA", qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("S_BB4H",       qty=tp2_qty, comment="TP2_BB1H")
        tp2_done := true

    if tp2_done and close >= strategy.position_avg_price
        strategy.close_all(comment="TP3_평단청산")

// ╔════════════════════════════════════════════════════════════╗
// ║  손절 (SL) — 우선순위                                      ║
// ╚════════════════════════════════════════════════════════════╝
// ── 롱 손절 ──
if in_long
    sl1 = pattern_sl_price > 0 and close < pattern_sl_price
    sl2 = (last_entry_type == "ema55" or last_entry_type == "ema55_vwma") and close < ema_55
    sl3 = zlsma_negative

    if sl1
        strategy.close_all(comment="SL_패턴저점이탈")
    else if sl2
        strategy.close_all(comment="SL_EMA55이탈")
    else if sl3
        strategy.close_all(comment="SL_ZLSMA음수")

// ── 숏 손절 ──
if in_short
    sl1 = pattern_sl_price > 0 and close > pattern_sl_price
    sl2 = (last_entry_type == "ema55" or last_entry_type == "ema55_vwma") and close > ema_55
    sl3 = zlsma_positive

    if sl1
        strategy.close_all(comment="SL_패턴고점돌파")
    else if sl2
        strategy.close_all(comment="SL_EMA55돌파")
    else if sl3
        strategy.close_all(comment="SL_ZLSMA양수")

// ╔════════════════════════════════════════════════════════════╗
// ║  ALMA 사전 알림                                            ║
// ╚════════════════════════════════════════════════════════════╝
alma_cross_up = ta.crossover(alma50, zlsma)
alma_cross_dn = ta.crossunder(alma50, zlsma)

// ╔════════════════════════════════════════════════════════════╗
// ║  시각화 — 이평매매v2 색상 체계 반영                         ║
// ╚════════════════════════════════════════════════════════════╝
grpCol = "MA 색상"
colZLS  = input.color(color.green,             "ZLSMA150", group=grpCol)
colVWMA = input.color(color.black,             "VWMA150",  group=grpCol)
colALMA = input.color(color.rgb(255,105,180),  "ALMA50",   group=grpCol)
colHMA  = input.color(color.white,             "HMA34",    group=grpCol)

grpBBCol = "BB 색상"
bbColUpper = input.color(color.new(color.red, 0),   "BB Upper", group=grpBBCol)
bbColMid   = input.color(color.new(color.blue, 0),  "BB Mid",   group=grpBBCol)
bbColLower = input.color(color.new(color.green, 0), "BB Lower", group=grpBBCol)
bbColFill  = input.color(color.new(color.rgb(33,150,243), 95), "BB Fill", group=grpBBCol)

// ── 이평매매v2 지표 ──
plot(shZLS ? zlsma : na, "ZLSMA150", colZLS, 2)
plot(vwma150,            "VWMA150",  colVWMA, 2)
plot(shALMA ? alma50 : na, "ALMA50", colALMA, 2)
plot(hma34,              "HMA34",    colHMA, 2)

// ── BB ──
pBBU = plot(bbUpper, "BB Upper", bbColUpper, 1, offset=bbOff)
pBBM = plot(bbBasis, "BB Mid",   bbColMid,   1, offset=bbOff)
pBBL = plot(bbLower, "BB Lower", bbColLower, 1, offset=bbOff)
fill(pBBU, pBBL, color=bbColFill, title="BB Fill")

// ── 7EMA ──
plot(ema_21,  "EMA21",  color.yellow, 2)
plot(ema_55,  "EMA55",  color.lime,   2)
plot(ema_100, "EMA100", color.aqua,   2)
plot(ema_200, "EMA200", color.purple, 2)
plot(ema_300, "EMA300", color.aqua,   1)
plot(ema_400, "EMA400", color.purple, 1)

// ── 5SMA ──
plot(sma_11,  "SMA11",  color.orange, 2)
plot(sma_23,  "SMA23",  color.purple, 2)
plot(sma_25,  "SMA25",  color.green,  2)
plot(sma_39,  "SMA39",  color.red,    2)
plot(sma_200, "SMA200", color.yellow, 2)

// ── 백테스트 구간 배경 ──
bgcolor(in_date_range ? color.new(color.blue, 95) : na, title="백테스트 구간")

// ── 진입 시그널 ──
plotshape(allow_long and long_cond3,                               style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.normal, title="L_EMA55+VWMA")
plotshape(allow_long and long_cond2 and not long_cond3,            style=shape.triangleup,   location=location.belowbar, color=color.lime,  size=size.small,  title="L_EMA55")
plotshape(allow_long and long_cond1 and not long_cond2 and not long_cond3, style=shape.triangleup, location=location.belowbar, color=color.aqua, size=size.tiny, title="L_EMA21")

plotshape(allow_short and short_cond3,                              style=shape.triangledown, location=location.abovebar, color=color.red,    size=size.normal, title="S_EMA55+VWMA")
plotshape(allow_short and short_cond2 and not short_cond3,          style=shape.triangledown, location=location.abovebar, color=color.orange, size=size.small,  title="S_EMA55")
plotshape(allow_short and short_cond1 and not short_cond2 and not short_cond3, style=shape.triangledown, location=location.abovebar, color=color.yellow, size=size.tiny, title="S_EMA21")

// ── ALMA 교차 ──
plotshape(alma_cross_up, style=shape.diamond, location=location.abovebar, color=color.teal,   size=size.tiny, title="ALMA↑", text="ALMA↑")
plotshape(alma_cross_dn, style=shape.diamond, location=location.belowbar, color=color.maroon, size=size.tiny, title="ALMA↓", text="ALMA↓")

// ── 거래량 서지 / SL 라인 ──
bgcolor(vol_surge ? color.new(color.yellow, 90) : na, title="거래량 서지")
plot(in_long  and pattern_sl_price > 0 ? pattern_sl_price : na, "SL Long",  color.red, 2, plot.style_cross)
plot(in_short and pattern_sl_price > 0 ? pattern_sl_price : na, "SL Short", color.red, 2, plot.style_cross)

// ── 우측 이름 라벨 ──
var label lblZLS  = na
var label lblVWMA = na
var label lblALMA = na
var label lblHMA  = na

if barstate.islast
    if not na(lblZLS)
        label.delete(lblZLS)
    if not na(lblVWMA)
        label.delete(lblVWMA)
    if not na(lblALMA)
        label.delete(lblALMA)
    if not na(lblHMA)
        label.delete(lblHMA)
    lblZLS  := label.new(bar_index, zlsma,  "ZLSMA150", style=label.style_label_right, textcolor=color.white, color=color.new(colZLS, 75),  size=size.tiny)
    lblVWMA := label.new(bar_index, vwma150, "VWMA150", style=label.style_label_right, textcolor=color.white, color=color.new(colVWMA, 75), size=size.tiny)
    lblALMA := label.new(bar_index, alma50,  "ALMA50",  style=label.style_label_right, textcolor=color.white, color=color.new(colALMA, 75), size=size.tiny)
    lblHMA  := label.new(bar_index, hma34,   "HMA34",   style=label.style_label_right, textcolor=color.black, color=color.new(colHMA, 75),  size=size.tiny)

// ╔════════════════════════════════════════════════════════════╗
// ║  알림                                                      ║
// ╚════════════════════════════════════════════════════════════╝
alertcondition(alma_cross_up, "ALMA 양수전환", "ALMA↑ ZLSMA 양수전환 가능 — 매수 준비")
alertcondition(long_cond2,    "롱 EMA55 신호", "EMA55 터치 + 캔들패턴 + 거래량 서지")
alertcondition(short_cond2,   "숏 EMA55 신호", "EMA55 터치 + 캔들패턴 + 거래량 서지")
