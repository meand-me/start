alertcondition(alma_cross_up, "ALMA 양수 전환", "ALMA 방향 전환! ZLSMA 양수 전환 가능성 있음. 매수 준비")
alertcondition(long_cond2,    "롱 EMA50 매수 신호", "EMA50 터치 + 캔들패턴 + 거래량 확인")
alertcondition(short_cond2,   "숏 EMA50 매도 신호", "EMA50 터치 + 캔들패턴 + 거래량 확인")
