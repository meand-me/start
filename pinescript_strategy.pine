// This Pine Script™ is subject to the Terms of Use at https://www.tradingview.com/pine-script-docs/
// © AutoTrading System - Backtest Strategy
//@version=6
strategy("자동매매 백테스트", overlay=true, default_qty_type=strategy.percent_of_equity,
         initial_capital=10000, commission_type=strategy.commission.percent,
         commission_value=0.04, slippage=1, pyramiding=4,
         calc_on_every_tick=false)

// ============================================================
// 입력값
// ============================================================
// -- 백테스트 기간 (에센셜 플랜용 코드 내 날짜 제한) --
i_start_year  = input.int(2025, "시작 연도")
i_start_month = input.int(8,    "시작 월", minval=1, maxval=12)
i_start_day   = input.int(1,    "시작 일", minval=1, maxval=31)
i_end_year    = input.int(2026, "종료 연도")
i_end_month   = input.int(3,    "종료 월", minval=1, maxval=12)
i_end_day     = input.int(20,   "종료 일", minval=1, maxval=31)

// -- 방향 설정 --
i_mode = input.string("롱", "매매 방향", options=["롱", "숏", "단타"])

// -- ZLSMA --
i_zlsma_len = input.int(150, "ZLSMA 길이", minval=10)

// -- EMA --
i_ema25  = input.int(25,  "EMA 25")
i_ema50  = input.int(50,  "EMA 50")
i_ema200 = input.int(200, "EMA 200")

// -- VWMA --
i_vwma_len = input.int(20, "VWMA 길이")

// -- ALMA --
i_alma_window = input.int(9,    "ALMA Window")
i_alma_offset = input.float(0.85, "ALMA Offset")
i_alma_sigma  = input.float(6.0,  "ALMA Sigma")

// -- 볼린저밴드 --
i_bb_len = input.int(20,   "BB 길이")
i_bb_std = input.float(2.0, "BB 표준편차")

// -- 거래량 --
i_vol_count = input.int(8,    "거래량 비교 캔들 수")
i_vol_mult  = input.float(2.0, "거래량 배수")

// -- 포지션 크기 (% of equity) --
i_size_ema25     = input.float(10, "EMA25 진입 크기 (%)")
i_size_ema50     = input.float(50, "EMA50 진입 크기 (%)")
i_size_ema50vwma = input.float(20, "EMA50+VWMA 진입 크기 (%)")
i_size_bb4h      = input.float(20, "4H BB하단 진입 크기 (%)")
i_max_position   = input.float(80, "최대 포지션 (%)")

// -- TP/SL --
i_tp1_pct = input.float(30, "TP1 청산 비율 (%)")
i_tp2_pct = input.float(30, "TP2 청산 비율 (%)")

// ============================================================
// 백테스트 기간 필터
// ============================================================
start_time = timestamp(i_start_year, i_start_month, i_start_day, 0, 0)
end_time   = timestamp(i_end_year,   i_end_month,   i_end_day,   23, 59)
in_date_range = time >= start_time and time <= end_time

// 기간 밖이면 포지션 전량 청산
if not in_date_range and strategy.position_size != 0
    strategy.close_all(comment="기간종료_전량청산")

// 배경색으로 백테스트 구간 표시
bgcolor(in_date_range ? color.new(color.blue, 95) : na, title="백테스트 구간")

// ============================================================
// 지표 계산
// ============================================================

// -- LSMA 함수 --
lsma(src, len) =>
    sum_x  = 0.0
    sum_y  = 0.0
    sum_xy = 0.0
    sum_x2 = 0.0
    for i = 0 to len - 1
        x = float(i)
        y = src[len - 1 - i]
        sum_x  += x
        sum_y  += y
        sum_xy += x * y
        sum_x2 += x * x
    slope     = (len * sum_xy - sum_x * sum_y) / (len * sum_x2 - sum_x * sum_x)
    intercept = (sum_y - slope * sum_x) / len
    intercept + slope * (len - 1)

// -- ZLSMA = 2 * LSMA - LSMA(LSMA) --
lsma1  = lsma(close, i_zlsma_len)
lsma2  = lsma(lsma1, i_zlsma_len)
zlsma  = 2 * lsma1 - lsma2

// -- EMA --
ema25  = ta.ema(close, i_ema25)
ema50  = ta.ema(close, i_ema50)
ema200 = ta.ema(close, i_ema200)

// -- VWMA --
vwma_val = ta.vwma(close, i_vwma_len)

// -- ALMA --
alma_val = ta.alma(close, i_alma_window, i_alma_offset, i_alma_sigma)

// -- 볼린저밴드 (현재 타임프레임) --
bb_mid   = ta.sma(close, i_bb_len)
bb_std   = ta.stdev(close, i_bb_len)
bb_upper = bb_mid + i_bb_std * bb_std
bb_lower = bb_mid - i_bb_std * bb_std

// -- 4시간봉 볼린저밴드 --
[bb4h_upper, bb4h_mid, bb4h_lower] = request.security(syminfo.tickerid, "240", [bb_mid + i_bb_std * bb_std, bb_mid, bb_mid - i_bb_std * bb_std])

// -- 1시간봉 볼린저밴드 (익절 기준) --
[bb1h_upper, bb1h_mid, bb1h_lower] = request.security(syminfo.tickerid, "60", [bb_mid + i_bb_std * bb_std, bb_mid, bb_mid - i_bb_std * bb_std])

// -- 15분봉 거래량 --
vol_15m       = request.security(syminfo.tickerid, "15", volume)
vol_15m_avg   = request.security(syminfo.tickerid, "15", ta.sma(volume, i_vol_count))
vol_surge     = vol_15m >= vol_15m_avg * i_vol_mult

// -- ZLSMA 1시간봉 (익절 기준) --
zlsma_1h = request.security(syminfo.tickerid, "60", zlsma)

// ============================================================
// 캔들 패턴 감지
// ============================================================

// -- 망치형 (Hammer) --
body       = math.abs(close - open)
total_range = high - low
lower_shadow = math.min(open, close) - low
upper_shadow = high - math.max(open, close)

is_hammer = total_range > 0 and
             lower_shadow >= 2 * body and
             upper_shadow <= body * 0.5 and
             body / total_range <= 0.35

// -- 강세 장악형 (Bullish Engulfing) --
prev_bearish      = close[1] < open[1]
curr_bullish      = close > open
bullish_engulfs   = open <= close[1] and close >= open[1]
is_bull_engulfing = prev_bearish and curr_bullish and bullish_engulfs

// -- 역망치형 (Inverted Hammer / Shooting Star) --
is_inv_hammer = total_range > 0 and
                 upper_shadow >= 2 * body and
                 lower_shadow <= body * 0.5 and
                 body / total_range <= 0.35

// -- 약세 장악형 (Bearish Engulfing) --
prev_bullish      = close[1] > open[1]
curr_bearish      = close < open
bearish_engulfs   = open >= close[1] and close <= open[1]
is_bear_engulfing = prev_bullish and curr_bearish and bearish_engulfs

// 패턴 종합
bullish_pattern = is_hammer or is_bull_engulfing
bearish_pattern = is_inv_hammer or is_bear_engulfing

// ============================================================
// 공통 조건
// ============================================================

// -- ZLSMA 양수 (가격이 ZLSMA 위) --
zlsma_positive = close > zlsma
zlsma_negative = close < zlsma

// -- EMA 터치 판정 (캔들 고저가가 EMA를 포함) --
touches_ema25 = low <= ema25 and high >= ema25
touches_ema50 = low <= ema50 and high >= ema50
touches_vwma  = low <= vwma_val and high >= vwma_val

// -- 종가 위치 --
close_above_ema25 = close > ema25
close_above_ema50 = close > ema50
close_below_ema25 = close < ema25
close_below_ema50 = close < ema50

// -- 4H 볼린저 터치 --
touches_bb4h_lower = low <= bb4h_lower
close_above_bb4h   = close > bb4h_lower
touches_bb4h_upper = high >= bb4h_upper
close_below_bb4h   = close < bb4h_upper

// ============================================================
// 매수 조건 (롱)
// ============================================================
long_common = in_date_range and zlsma_positive and vol_surge and bullish_pattern

// 조건1: EMA25 터치 (선진입 10%)
long_cond1 = long_common and touches_ema25 and close_above_ema25

// 조건2: EMA50 터치 (메인 50%)
long_cond2 = long_common and touches_ema50 and close_above_ema50

// 조건3: EMA50 + VWMA 동시 터치 (강한 매수 20%)
long_cond3 = long_common and touches_ema50 and touches_vwma and close_above_ema50

// 조건4: 4H 볼린저 하단 터치 (20%)
long_cond4 = long_common and touches_bb4h_lower and close_above_bb4h

// ============================================================
// 매도 조건 (숏)
// ============================================================
short_common = in_date_range and zlsma_negative and vol_surge and bearish_pattern

// 조건1: EMA25 터치 (선진입 10%)
short_cond1 = short_common and touches_ema25 and close_below_ema25

// 조건2: EMA50 터치 (메인 50%)
short_cond2 = short_common and touches_ema50 and close_below_ema50

// 조건3: EMA50 + VWMA 동시 터치 (강한 매도 20%)
short_cond3 = short_common and touches_ema50 and touches_vwma and close_below_ema50

// 조건4: 4H 볼린저 상단 터치 (20%)
short_cond4 = short_common and touches_bb4h_upper and close_below_bb4h

// ============================================================
// 포지션 추적 변수
// ============================================================
var float total_invested_pct = 0.0   // 누적 투자 비율
var bool  tp1_done = false
var bool  tp2_done = false
var float pattern_sl_price = 0.0     // 캔들 패턴 저점/고점 (SL 기준)
var string last_entry_type = ""      // 마지막 진입 조건

// 포지션 유무
in_long  = strategy.position_size > 0
in_short = strategy.position_size < 0
no_position = strategy.position_size == 0

// 포지션 리셋
if no_position
    total_invested_pct := 0.0
    tp1_done := false
    tp2_done := false
    pattern_sl_price := 0.0
    last_entry_type := ""

// 추가 진입 가능 여부
can_add_long  = total_invested_pct < i_max_position
can_add_short = total_invested_pct < i_max_position

// ============================================================
// 롱 방향 진입
// ============================================================
allow_long  = i_mode == "롱" or i_mode == "단타"
allow_short = i_mode == "숏" or i_mode == "단타"

// -- 캔들 패턴 저점 (SL 기준) --
bull_pattern_low = is_bull_engulfing ? low[1] : low
bear_pattern_high = is_bear_engulfing ? high[1] : high

// 조건3 우선 (EMA50 + VWMA > EMA50 > EMA25)
if allow_long and can_add_long and long_cond3 and (total_invested_pct + i_size_ema50vwma) <= i_max_position
    entry_size = i_size_ema50vwma
    strategy.entry("Long_EMA50VWMA", strategy.long, qty=strategy.equity * entry_size / 100 / close)
    total_invested_pct += entry_size
    pattern_sl_price := bull_pattern_low
    last_entry_type := "ema50_vwma"
else if allow_long and can_add_long and long_cond2 and (total_invested_pct + i_size_ema50) <= i_max_position
    entry_size = i_size_ema50
    strategy.entry("Long_EMA50", strategy.long, qty=strategy.equity * entry_size / 100 / close)
    total_invested_pct += entry_size
    pattern_sl_price := bull_pattern_low
    last_entry_type := "ema50"
else if allow_long and can_add_long and long_cond1 and (total_invested_pct + i_size_ema25) <= i_max_position
    entry_size = i_size_ema25
    strategy.entry("Long_EMA25", strategy.long, qty=strategy.equity * entry_size / 100 / close)
    total_invested_pct += entry_size
    pattern_sl_price := bull_pattern_low
    last_entry_type := "ema25"

// 조건4: 4H BB 하단 (독립 조건)
if allow_long and can_add_long and long_cond4 and (total_invested_pct + i_size_bb4h) <= i_max_position
    entry_size = i_size_bb4h
    strategy.entry("Long_BB4H", strategy.long, qty=strategy.equity * entry_size / 100 / close)
    total_invested_pct += entry_size
    if pattern_sl_price == 0.0
        pattern_sl_price := bull_pattern_low
    last_entry_type := "bb4h"

// ============================================================
// 숏 방향 진입
// ============================================================
if allow_short and can_add_short and short_cond3 and (total_invested_pct + i_size_ema50vwma) <= i_max_position
    entry_size = i_size_ema50vwma
    strategy.entry("Short_EMA50VWMA", strategy.short, qty=strategy.equity * entry_size / 100 / close)
    total_invested_pct += entry_size
    pattern_sl_price := bear_pattern_high
    last_entry_type := "ema50_vwma"
else if allow_short and can_add_short and short_cond2 and (total_invested_pct + i_size_ema50) <= i_max_position
    entry_size = i_size_ema50
    strategy.entry("Short_EMA50", strategy.short, qty=strategy.equity * entry_size / 100 / close)
    total_invested_pct += entry_size
    pattern_sl_price := bear_pattern_high
    last_entry_type := "ema50"
else if allow_short and can_add_short and short_cond1 and (total_invested_pct + i_size_ema25) <= i_max_position
    entry_size = i_size_ema25
    strategy.entry("Short_EMA25", strategy.short, qty=strategy.equity * entry_size / 100 / close)
    total_invested_pct += entry_size
    pattern_sl_price := bear_pattern_high
    last_entry_type := "ema25"

if allow_short and can_add_short and short_cond4 and (total_invested_pct + i_size_bb4h) <= i_max_position
    entry_size = i_size_bb4h
    strategy.entry("Short_BB4H", strategy.short, qty=strategy.equity * entry_size / 100 / close)
    total_invested_pct += entry_size
    if pattern_sl_price == 0.0
        pattern_sl_price := bear_pattern_high
    last_entry_type := "bb4h"

// ============================================================
// 익절 (TP)
// ============================================================

// -- 롱 익절 --
if in_long
    pos_qty = math.abs(strategy.position_size)
    // TP1: ZLSMA 도달 → 30% 청산
    if not tp1_done and close >= zlsma_1h
        tp1_qty = pos_qty * (i_tp1_pct / 100)
        strategy.close("Long_EMA25",     qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("Long_EMA50",     qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("Long_EMA50VWMA", qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("Long_BB4H",      qty=tp1_qty, comment="TP1_ZLSMA")
        tp1_done := true

    // TP2: 1H 볼린저 상단 도달 → 30% 청산
    if not tp2_done and tp1_done and close >= bb1h_upper
        remaining_qty = math.abs(strategy.position_size)
        tp2_qty = remaining_qty * (i_tp2_pct / (100 - i_tp1_pct)) * 100 / 100
        strategy.close("Long_EMA25",     qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("Long_EMA50",     qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("Long_EMA50VWMA", qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("Long_BB4H",      qty=tp2_qty, comment="TP2_BB1H")
        tp2_done := true

    // TP3: TP2 완료 후 평단 이하 도달 → 나머지 전량 청산
    if tp2_done and close <= strategy.position_avg_price
        strategy.close_all(comment="TP3_평단청산")

// -- 숏 익절 --
if in_short
    pos_qty = math.abs(strategy.position_size)
    // TP1: ZLSMA 도달 (가격이 ZLSMA 아래)
    if not tp1_done and close <= zlsma_1h
        tp1_qty = pos_qty * (i_tp1_pct / 100)
        strategy.close("Short_EMA25",     qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("Short_EMA50",     qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("Short_EMA50VWMA", qty=tp1_qty, comment="TP1_ZLSMA")
        strategy.close("Short_BB4H",      qty=tp1_qty, comment="TP1_ZLSMA")
        tp1_done := true

    // TP2: 1H 볼린저 하단 도달
    if not tp2_done and tp1_done and close <= bb1h_lower
        remaining_qty = math.abs(strategy.position_size)
        tp2_qty = remaining_qty * (i_tp2_pct / (100 - i_tp1_pct)) * 100 / 100
        strategy.close("Short_EMA25",     qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("Short_EMA50",     qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("Short_EMA50VWMA", qty=tp2_qty, comment="TP2_BB1H")
        strategy.close("Short_BB4H",      qty=tp2_qty, comment="TP2_BB1H")
        tp2_done := true

    // TP3: 평단 이상 도달 → 전량 청산
    if tp2_done and close >= strategy.position_avg_price
        strategy.close_all(comment="TP3_평단청산")

// ============================================================
// 손절 (SL) — 우선순위 적용
// ============================================================

// -- 롱 손절 --
if in_long
    // 1순위: 캔들 패턴 저점 이탈
    sl1_long = pattern_sl_price > 0 and close < pattern_sl_price
    // 2순위: EMA50 완전 이탈 (EMA50 진입일 때)
    sl2_long = (last_entry_type == "ema50" or last_entry_type == "ema50_vwma") and close < ema50
    // 3순위: ZLSMA 음수 전환
    sl3_long = zlsma_negative

    if sl1_long
        strategy.close_all(comment="SL_패턴저점이탈")
    else if sl2_long
        strategy.close_all(comment="SL_EMA50이탈")
    else if sl3_long
        strategy.close_all(comment="SL_ZLSMA음수")

// -- 숏 손절 --
if in_short
    // 1순위: 캔들 패턴 고점 돌파
    sl1_short = pattern_sl_price > 0 and close > pattern_sl_price
    // 2순위: EMA50 완전 돌파
    sl2_short = (last_entry_type == "ema50" or last_entry_type == "ema50_vwma") and close > ema50
    // 3순위: ZLSMA 양수 전환
    sl3_short = zlsma_positive

    if sl1_short
        strategy.close_all(comment="SL_패턴고점돌파")
    else if sl2_short
        strategy.close_all(comment="SL_EMA50돌파")
    else if sl3_short
        strategy.close_all(comment="SL_ZLSMA양수")

// ============================================================
// ALMA 사전 알림 (차트 시각화)
// ============================================================
alma_cross_up = ta.crossover(alma_val, zlsma)
alma_cross_dn = ta.crossunder(alma_val, zlsma)

// ============================================================
// 시각화
// ============================================================

// -- 지표 플롯 --
plot(zlsma,    "ZLSMA",    color=color.new(color.orange, 0), linewidth=2)
plot(ema25,    "EMA 25",   color=color.new(color.blue, 30))
plot(ema50,    "EMA 50",   color=color.new(color.red, 30),   linewidth=2)
plot(ema200,   "EMA 200",  color=color.new(color.gray, 30),  linewidth=2)
plot(vwma_val, "VWMA",     color=color.new(color.purple, 40))
plot(alma_val, "ALMA",     color=color.new(color.teal, 40))

// -- 볼린저밴드 --
p_bbu = plot(bb_upper, "BB Upper", color=color.new(color.gray, 60))
p_bbl = plot(bb_lower, "BB Lower", color=color.new(color.gray, 60))
fill(p_bbu, p_bbl, color=color.new(color.gray, 90))

// -- 진입 시그널 표시 --
plotshape(allow_long and long_cond3,  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0),  size=size.normal, title="Long EMA50+VWMA")
plotshape(allow_long and long_cond2 and not long_cond3, style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, title="Long EMA50")
plotshape(allow_long and long_cond1 and not long_cond2 and not long_cond3, style=shape.triangleup, location=location.belowbar, color=color.new(color.aqua, 0), size=size.tiny, title="Long EMA25")

plotshape(allow_short and short_cond3, style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0),    size=size.normal, title="Short EMA50+VWMA")
plotshape(allow_short and short_cond2 and not short_cond3, style=shape.triangledown, location=location.abovebar, color=color.new(color.orange, 0), size=size.small, title="Short EMA50")
plotshape(allow_short and short_cond1 and not short_cond2 and not short_cond3, style=shape.triangledown, location=location.abovebar, color=color.new(color.yellow, 0), size=size.tiny, title="Short EMA25")

// -- ALMA 교차 알림 --
plotshape(alma_cross_up, style=shape.diamond, location=location.abovebar, color=color.new(color.teal, 0),   size=size.tiny, title="ALMA↑", text="ALMA↑")
plotshape(alma_cross_dn, style=shape.diamond, location=location.belowbar, color=color.new(color.maroon, 0), size=size.tiny, title="ALMA↓", text="ALMA↓")

// -- 거래량 서지 배경 --
bgcolor(vol_surge ? color.new(color.yellow, 90) : na, title="거래량 서지")

// -- SL 라인 --
plot(in_long and pattern_sl_price > 0 ? pattern_sl_price : na, "SL Price", color=color.new(color.red, 0), style=plot.style_cross, linewidth=2)
plot(in_short and pattern_sl_price > 0 ? pattern_sl_price : na, "SL Price Short", color=color.new(color.red, 0), style=plot.style_cross, linewidth=2)

// ============================================================
// 알림
